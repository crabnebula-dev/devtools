{
  "name": "spa-client",
  "private": true,
  "version": "0.0.0",
  "description": "Solid CSR Template",
  "type": "module",
  "license": "PolyForm-Noncommercial-1.0.0",
  "author": "CrabNebula <hello@crabnebula.dev>",
  "scripts": {
    "proto": "protoc --ts_out src/lib/proto --proto_path ../../crates/wire/proto ../../crates/wire/proto/common.proto ../../crates/wire/proto/instrument.proto ../../crates/wire/proto/logs.proto ../../crates/wire/proto/spans.proto ../../crates/wire/proto/tauri.proto ../../crates/wire/proto/sources.proto ../../crates/wire/proto/meta.proto ../../crates/wire/proto/health.proto",
    "dev": "pnpm proto --experimental_allow_proto3_optional && vite",
    "prebuild": "node csp.js -i",
    "build": "pnpm proto && vite build",
    "preview": "pnpm proto && vite preview",
    "format": "prettier --write --cache .",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --fix --ext .ts,.tsx",
    "test": "cross-env TZ=UTC pnpm proto && vitest",
    "prepare": "cd ../.. && husky clients/web/.husky"
  },
  "lint-staged": {
    "*": "pnpm format",
    "*.{ts,tsx}": "pnpm lint"
  },
  "devDependencies": {
    "@protobuf-ts/protoc": "^2.11.1",
    "@shikijs/transformers": "^1.29.2",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "autoprefixer": "^10.4.27",
    "cross-env": "^7.0.3",
    "csp-header": "^5.2.1",
    "eslint": "^10.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-solid": "^0.13.2",
    "husky": "^9.1.7",
    "jsdom": "^24.1.3",
    "lint-staged": "^15.5.2",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vite-plugin-solid": "^2.11.10",
    "vite-plugin-static-copy": "^1.0.6",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "@crabnebula/file-icons": "^0.1.0",
    "@kobalte/core": "^0.12.6",
    "@kobalte/tailwindcss": "^0.9.0",
    "@protobuf-ts/grpcweb-transport": "^2.11.1",
    "@protobuf-ts/plugin": "^2.11.1",
    "@protobuf-ts/runtime": "^2.11.1",
    "@protobuf-ts/runtime-rpc": "^2.11.1",
    "@sentry/browser": "^7.120.4",
    "@sentry/vite-plugin": "^2.23.1",
    "@solid-primitives/map": "^0.4.13",
    "@solid-primitives/script-loader": "^2.3.2",
    "@solidjs/router": "^0.12.5",
    "@tanstack/solid-virtual": "^3.13.21",
    "clsx": "^2.1.1",
    "csp_evaluator": "^1.1.5",
    "json-schema-library": "^9.3.5",
    "shiki": "^1.29.2",
    "solid-js": "^1.9.11",
    "solid-markdown": "^1.2.2",
    "split.js": "^1.6.5",
    "tailwind-scrollbar": "^3.1.0",
    "zod": "^3.25.76"
  }
}
